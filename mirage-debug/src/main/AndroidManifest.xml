<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      This is the mirage-debug artifact's manifest. Consumers add mirage-debug via
      debugImplementation, so this provider merges into the app's DEBUG build only, never release.
      Auto-registers the installer, which enables corpus capture and starts the HTTP control server.
      Authority is namespaced by the host applicationId.
    -->
    <application>
        <provider
            android:name="com.hyundai.airlab.mirage.MirageDebugInstaller"
            android:authorities="${applicationId}.mirage"
            android:exported="false" />
    </application>
</manifest>
