<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      Debug source set only → merges into the host app's DEBUG variant, never release.
      Auto-registers the installer, which points Mirage at the on-device dir and starts the
      HTTP control server. Authority is namespaced by the host applicationId.
    -->
    <application>
        <provider
            android:name="com.hyundai.airlab.mirage.MirageDebugInstaller"
            android:authorities="${applicationId}.mirage"
            android:exported="false" />
    </application>
</manifest>
